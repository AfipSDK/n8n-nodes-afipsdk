{
	"name": "n8n-nodes-afipsdk",
	"version": "1.0.1",
	"description": "n8n nodes for Afip SDK integration.",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "AfipSDK team",
		"email": "ayuda@afipsdk.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/AfipSDK/n8n-nodes-afipsdk"
	},
	"publishConfig": {
		"provenance": true
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build && npm run lint"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 2,
		"strict": true,
		"credentials": [
			"dist/credentials/AfipSdkApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/AfipSdk/AfipSdk.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
